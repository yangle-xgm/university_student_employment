<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.employment.learning.mapper.LearningRecordMapper">
    
    <select id="findByStudentId" resultType="com.example.employment.learning.entity.LearningRecord">
        SELECT * FROM learning_records WHERE student_id = #{studentId} ORDER BY created_at DESC
    </select>
    
    <select id="findByStudentIdAndResourceId" resultType="com.example.employment.learning.entity.LearningRecord">
        SELECT * FROM learning_records WHERE student_id = #{studentId} AND resource_id = #{resourceId}
    </select>
    
</mapper>