<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.employment.learning.mapper.LearningPathResourceMapper">
    
    <select id="findByPathId" resultType="com.example.employment.learning.entity.LearningPathResource">
        SELECT * FROM learning_path_resources WHERE path_id = #{pathId} ORDER BY sort_order ASC
    </select>
    
</mapper>