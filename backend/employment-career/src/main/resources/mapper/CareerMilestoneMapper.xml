<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.employment.career.mapper.CareerMilestoneMapper">
    
    <select id="findByPlanId" resultType="com.example.employment.career.entity.CareerMilestone">
        SELECT * FROM career_milestones WHERE plan_id = #{planId} ORDER BY target_date ASC
    </select>
    
</mapper>