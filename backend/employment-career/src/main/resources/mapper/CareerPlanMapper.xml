<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.employment.career.mapper.CareerPlanMapper">
    
    <select id="findByStudentId" resultType="com.example.employment.career.entity.CareerPlan">
        SELECT * FROM career_plans WHERE student_id = #{studentId} ORDER BY created_at DESC
    </select>
    
</mapper>