<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.employment.interview.mapper.InterviewEvaluationMapper">

    <select id="findByInterviewId" resultType="com.example.employment.interview.entity.InterviewEvaluation">
        SELECT * FROM interview_evaluations WHERE interview_id = #{interviewId} ORDER BY created_at DESC
    </select>

</mapper>