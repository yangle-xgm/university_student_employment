<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.employment.assessment.mapper.AssessmentReportMapper">
    
    <select id="findByStudentId" resultType="com.example.employment.assessment.entity.AssessmentReport">
        SELECT * FROM assessment_reports WHERE student_id = #{studentId} ORDER BY generated_at DESC
    </select>
    
    <select id="findByRecordId" resultType="com.example.employment.assessment.entity.AssessmentReport">
        SELECT * FROM assessment_reports WHERE record_id = #{recordId}
    </select>
    
</mapper>