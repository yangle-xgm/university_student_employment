<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.employment.assessment.mapper.AssessmentQuestionMapper">
    
    <select id="findByAssessmentId" resultType="com.example.employment.assessment.entity.AssessmentQuestion">
        SELECT * FROM assessment_questions WHERE assessment_id = #{assessmentId} ORDER BY sort_order ASC
    </select>
    
</mapper>