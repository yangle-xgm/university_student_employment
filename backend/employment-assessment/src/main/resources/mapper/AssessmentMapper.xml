<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.employment.assessment.mapper.AssessmentMapper">
    
    <select id="findByStatus" resultType="com.example.employment.assessment.entity.Assessment">
        SELECT * FROM assessments WHERE status = #{status} ORDER BY created_at DESC
    </select>
    
</mapper>